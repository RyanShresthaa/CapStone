# Free API Keys - Copy this to .env and add your actual keys

# OpenWeatherMap API (Free: 1000 calls/day)
# Sign up at: https://openweathermap.org/api
REACT_APP_OPENWEATHER_API_KEY=your_openweather_key_here

# Optional: Mapbox (Free tier: 50,000 map loads/month)
# Sign up at: https://www.mapbox.com/
REACT_APP_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# App Configuration
REACT_APP_APP_NAME=NepGo
REACT_APP_VERSION=1.0.0

# API URLs
REACT_APP_WEATHER_API_URL=https://api.openweathermap.org/data/2.5
