# Local MongoDB:
# MONGO_URI=mongodb://127.0.0.1:27017/nepgo

# MongoDB Atlas — copy a FRESH string from Atlas → Connect → Drivers (old hostnames give querySrv ENOTFOUND).
# SRV form:
# MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/nepgo?retryWrites=true&w=majority
# If SRV keeps failing, use the standard (multi-host) URI from the same screen — starts with mongodb:// and lists :27017 hosts.

JWT_SECRET=use-a-long-random-string-in-production
PORT=5000

# Optional: enables POST /api/admin/treks/import with header X-Admin-Key: <same value>
# ADMIN_API_KEY=your-secret-key-here

# Comma-separated browser origins allowed by CORS (production). Leave unset in dev to allow all.
# CLIENT_URL=http://localhost:3000

OPENWEATHER_API_KEY=

# If mongodb+srv fails with querySrv ECONNREFUSED, the server defaults to Google/Cloudflare DNS for that lookup.
# Set to false to use only Windows DNS:
# MONGO_USE_PUBLIC_DNS=false
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
